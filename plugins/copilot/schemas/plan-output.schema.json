{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "summary", "steps", "risks", "open_questions"],
  "properties": {
    "verdict": { "type": "string", "enum": ["ready", "needs-clarification"] },
    "summary": { "type": "string", "minLength": 1 },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["order", "title", "description", "files"],
        "properties": {
          "order": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "files": { "type": "array", "items": { "type": "string" } },
          "estimated_size": { "type": "string", "enum": ["small", "medium", "large"] }
        }
      }
    },
    "risks": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "open_questions": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  }
}
